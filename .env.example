# ─────────────────────────────────────────────────────────────
#  InstaMall Frontend — Environment Variables Template
#  Copy this file to .env.local for local dev, or set these
#  variables in the Vercel dashboard for production.
# ─────────────────────────────────────────────────────────────

# URL of your deployed Express backend (server-side, Vercel rewrites proxy)
BACKEND_URL=https://instatrustedmall-backend.onrender.com

# Leave blank to use the Next.js rewrite proxy, or set directly if needed
NEXT_PUBLIC_API_URL=

# Must point directly to your backend — Next.js cannot proxy WebSockets
NEXT_PUBLIC_SOCKET_URL=https://instatrustedmall-backend.onrender.com

# App metadata
NEXT_PUBLIC_APP_NAME=InstaMall
NEXT_PUBLIC_APP_VERSION=1.0.0
